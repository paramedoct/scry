#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <subject>:<source> <file...>" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/db.sh \
  utils/environment.sh \
  utils/image.sh \
  utils/classification.sh \
  utils/archive.sh

gather_add_file() {
  local subject
  local source
  local input
  local mime
  local status
  subject=$1
  source=$2
  input=$3
  if [ ! -f "$input" ] || [ ! -r "$input" ]; then
    echo "input is not a readable file: $input" >&2
    return 1
  fi
  mime=$(file -b --mime-type -- "$input")
  case "$mime" in
    application/zip | application/x-zip | application/x-zip-compressed)
      archive_add "$subject" "$source" "$input" || status=$?
      ;;
    *)
      image_add "$subject" "$source" "$input" || status=$?
      ;;
  esac
  [ "${status:-0}" -eq 2 ] || return "${status:-0}"
}

main() {
  local location
  local subject
  local source
  local input
  [ "$#" -ge 2 ] || usage
  location=$1
  shift
  environment_prepare
  IFS=: read -r subject source \
    < <(classification_parse_location "$location" add)
  for input in "$@"; do
    gather_add_file "$subject" "$source" "$input"
  done
}

main "$@"
