#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 [artist[:cat[:topic]]]" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/db.sh \
  utils/environment.sh \
  utils/image.sh \
  utils/classification.sh \
  utils/sequence.sh \
  utils/search.sh \
  utils/display.sh

main() {
  local targets
  local arg
  local location
  local location_set
  local status
  local -a result_targets
  location=
  location_set=0
  result_targets=()
  case "$#" in
    0) ;;
    1)
      case "$1" in
        -*) usage ;;
      esac
      location=$1
      location_set=1
      ;;
    2)
      [ "$1" = -- ] || usage
      location=$2
      location_set=1
      ;;
    *) usage ;;
  esac
  environment_prepare
  if [ -t 0 ] && [ -t 1 ]; then
    display_cursor_hide
    trap display_cursor_show EXIT
  fi
  DISPLAY_SELECTED=0
  while :; do
    result_targets=()
    if [ "$location_set" -eq 1 ]; then
      targets=$(search_targets "$location")
    else
      targets=$(search_targets)
    fi
    while IFS= read -r arg; do
      [ -n "$arg" ] || continue
      result_targets+=("$arg")
    done <<<"$targets"
    if [ ! -t 0 ] || [ ! -t 1 ]; then
      if [ "${#result_targets[@]}" -gt 0 ]; then
        printf '%s\n' "${result_targets[@]}"
      fi
      return 0
    fi
    if display_browser "${result_targets[@]}"; then
      return 0
    else
      status=$?
    fi
    [ "$status" -eq 10 ] || return "$status"
  done
}

main "$@"
