#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <name> [--limit <count>]" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/db.sh \
  utils/profile.sh \
  utils/image.sh \
  utils/sequence.sh \
  utils/display.sh

main() {
  local name
  local limit
  local ids
  local id
  local -a image_ids
  [ "$#" -ge 1 ] || usage
  name=$1
  shift
  limit=12
  image_ids=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --limit)
        [ "$#" -ge 2 ] || usage
        limit=$2
        shift 2
        ;;
      --limit=*) limit=${1#--limit=}; shift ;;
      *) usage ;;
    esac
  done
  display_validate_limit "$limit"
  profile_prepare
  ids=$(sequence_image_ids "$name")
  while IFS= read -r id; do
    [ -n "$id" ] || continue
    image_ids+=("$id")
  done <<<"$ids"
  display_pager "$limit" "${image_ids[@]}"
}

main "$@"
