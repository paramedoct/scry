#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 [tag...] [--limit <count|auto>]" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/db.sh \
  utils/profile.sh \
  utils/object.sh \
  utils/image.sh \
  utils/sequence.sh \
  utils/tag.sh \
  utils/search.sh \
  utils/action.sh \
  utils/display.sh

main() {
  local limit
  local targets
  local arg
  local grid_cols
  local status
  local -a tags
  local -a result_targets
  DISPLAY_GRID_COLS=auto
  limit=auto
  tags=()
  result_targets=()
  while [ "$#" -gt 0 ]; do
    arg=$1
    shift
    case "$arg" in
      --limit)
        [ "$#" -ge 1 ] || usage
        limit=$1
        shift
        ;;
      --limit=*) limit=${arg#--limit=} ;;
      --) tags+=("$@"); break ;;
      -*) usage ;;
      *) tags+=("$arg") ;;
    esac
  done
  if [ "$limit" = auto ]; then
    if [ -t 0 ] && [ -t 1 ]; then
      read -r limit grid_cols < <(display_auto_layout)
      DISPLAY_GRID_COLS=$grid_cols
    else
      limit=12
    fi
  else
    display_validate_limit "$limit"
  fi
  profile_prepare
  DISPLAY_PAGE=0
  while :; do
    result_targets=()
    targets=$(search_targets "${tags[@]}")
    while IFS= read -r arg; do
      [ -n "$arg" ] || continue
      result_targets+=("$arg")
    done <<<"$targets"
    if display_pager "$limit" "${result_targets[@]}"; then
      return 0
    else
      status=$?
    fi
    [ "$status" -eq 10 ] || return "$status"
  done
}

main "$@"
