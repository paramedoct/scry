#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 [artist[:cat[:topic]]] [--limit <count|auto>]" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/db.sh \
  utils/profile.sh \
  utils/object.sh \
  utils/image.sh \
  utils/album.sh \
  utils/sequence.sh \
  utils/search.sh \
  utils/action.sh \
  utils/pair.sh \
  utils/display.sh

main() {
  local limit
  local targets
  local arg
  local location
  local location_set
  local grid_cols
  local status
  local -a result_targets
  DISPLAY_GRID_COLS=auto
  limit=auto
  location=
  location_set=0
  result_targets=()
  while [ "$#" -gt 0 ]; do
    arg=$1
    shift
    case "$arg" in
      --limit)
        [ "$#" -ge 1 ] || usage
        limit=$1
        shift
        ;;
      --limit=*) limit=${arg#--limit=} ;;
      --)
        [ "$#" -le 1 ] || usage
        if [ "$#" -eq 1 ]; then
          [ "$location_set" -eq 0 ] || usage
          location=$1
          location_set=1
        fi
        break
        ;;
      -*) usage ;;
      *)
        [ "$location_set" -eq 0 ] || usage
        location=$arg
        location_set=1
        ;;
    esac
  done
  if [ "$limit" = auto ]; then
    if [ -t 0 ] && [ -t 1 ]; then
      read -r limit grid_cols < <(display_auto_layout)
      DISPLAY_GRID_COLS=$grid_cols
    else
      limit=10
      DISPLAY_GRID_COLS=5
    fi
  else
    display_validate_limit "$limit"
    limit=$((10#$limit))
    DISPLAY_GRID_COLS=$(((limit + 1) / 2))
  fi
  profile_prepare
  if [ -t 0 ] && [ -t 1 ]; then
    display_cursor_hide
    trap display_cursor_show EXIT
  fi
  DISPLAY_PAGE=0
  while :; do
    result_targets=()
    if [ "$location_set" -eq 1 ]; then
      targets=$(search_targets "$location")
    else
      targets=$(search_targets)
    fi
    while IFS= read -r arg; do
      [ -n "$arg" ] || continue
      result_targets+=("$arg")
    done <<<"$targets"
    if display_pager "$limit" "${result_targets[@]}"; then
      return 0
    else
      status=$?
    fi
    [ "$status" -eq 10 ] || return "$status"
  done
}

main "$@"
