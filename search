#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 [tag...] [--limit <count>]" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/db.sh \
  utils/profile.sh \
  utils/image.sh \
  utils/tag.sh \
  utils/search.sh \
  utils/display.sh

main() {
  local limit
  local targets
  local arg
  local -a tags
  local -a result_targets
  limit=12
  tags=()
  result_targets=()
  while [ "$#" -gt 0 ]; do
    arg=$1
    shift
    case "$arg" in
      --limit)
        [ "$#" -ge 1 ] || usage
        limit=$1
        shift
        ;;
      --limit=*) limit=${arg#--limit=} ;;
      --) tags+=("$@"); break ;;
      -*) usage ;;
      *) tags+=("$arg") ;;
    esac
  done
  display_validate_limit "$limit"
  profile_prepare
  targets=$(search_targets "${tags[@]}")
  while IFS= read -r arg; do
    [ -n "$arg" ] || continue
    result_targets+=("$arg")
  done <<<"$targets"
  display_pager "$limit" "${result_targets[@]}"
}

main "$@"
