#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <artist>:<cat>[:<topic>] <file...>" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/db.sh \
  utils/profile.sh \
  utils/object.sh \
  utils/image.sh \
  utils/album.sh \
  utils/sequence.sh \
  utils/archive.sh

add_file() {
  local artist
  local album
  local character
  local input
  local mime
  local status
  artist=$1
  album=$2
  character=$3
  input=$4
  if [ ! -f "$input" ] || [ ! -r "$input" ]; then
    echo "input is not a readable file: $input" >&2
    return 1
  fi
  mime=$(file -b --mime-type -- "$input")
  case "$mime" in
    application/zip | application/x-zip | application/x-zip-compressed)
      archive_add "$artist" "$album" "$character" "$input"
      ;;
    *)
      if image_add "$artist" "$album" "$character" "$input"; then
        return 0
      else
        status=$?
      fi
      if [ "$status" -eq 2 ]; then
        return 0
      fi
      return "$status"
      ;;
  esac
}

main() {
  local location
  local artist
  local album
  local character
  local input
  local status
  [ "$#" -ge 2 ] || usage
  location=$1
  shift
  profile_prepare
  IFS=$'\t' read -r artist album character \
    < <(album_parse_add_location "$location")
  for input in "$@"; do
    if add_file "$artist" "$album" "$character" "$input"; then
      continue
    else
      status=$?
    fi
    if [ "$status" -eq 2 ]; then
      continue
    fi
    return "$status"
  done
}

main "$@"
